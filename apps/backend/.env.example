# ─────────────────────────────────────────────
# BASE DE DATOS
# ─────────────────────────────────────────────

# Conexión pooled de Prisma (usa PgBouncer de Supabase en producción)
DATABASE_URL="postgresql://postgres:password@db.xxxx.supabase.co:6543/postgres?pgbouncer=true&connection_limit=1"

# Conexión directa (usada por prisma migrate — bypasa PgBouncer)
DIRECT_URL="postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres"

# ─────────────────────────────────────────────
# SERVIDOR
# ─────────────────────────────────────────────

# Puerto en el que arranca NestJS (default: 3000)
PORT=3000

# Entorno de ejecución — en production activa SSL para PostgreSQL
NODE_ENV=development

# ─────────────────────────────────────────────
# AUTH / JWT
# ─────────────────────────────────────────────

# Clave secreta para firmar y verificar JWTs — debe ser larga y aleatoria
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# ─────────────────────────────────────────────
# SUPABASE (storage de imágenes)
# ─────────────────────────────────────────────

# URL del proyecto Supabase (se encuentra en Settings > API)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Service role key — permite acceso total al storage sin RLS (Settings > API)
# NUNCA exponer en el frontend
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key-here

# ─────────────────────────────────────────────
# MERCADO PAGO
# ─────────────────────────────────────────────

# Access token del vendedor — autoriza cobros en su nombre
# Se sobreescribe por restaurante vía OAuth; este es el token de la app global
MP_ACCESS_TOKEN=APP_USR-0000000000000000-000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-000000000

# Client ID y secret de la aplicación MP — necesarios para el flujo OAuth
# Se obtienen en https://www.mercadopago.com.ar/developers/panel
MP_CLIENT_ID=0000000000000000
MP_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URI de callback OAuth — debe coincidir exactamente con la configurada en el panel de MP
MP_REDIRECT_URI=http://localhost:3000/api/payments/oauth/callback

# URL del webhook que MP llama al actualizar un pago
# En desarrollo usar ngrok o similar: ngrok http 3000
MP_WEBHOOK_URL=https://tu-dominio.com/api/payments/webhook

# Redirects del frontend después del checkout de MP.
MP_SUCCESS_URL=http://localhost:5173/pago/exitoso
MP_FAILURE_URL=http://localhost:5173/pago/fallido
MP_PENDING_URL=http://localhost:5173/pago/pendiente

# ─────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────

# Lista de origins permitidos separados por coma (producción)
# En desarrollo todos los localhost son permitidos automáticamente
CORS_ORIGINS=https://admin.menyu.com,https://staff.menyu.com,https://menu.menyu.com

# Patrones regex de origins adicionales (útil para URLs de preview de Vercel)
# Ejemplo: .*\.vercel\.app  — permite cualquier preview de Vercel
CORS_ORIGIN_PATTERNS=.*-menyu\.vercel\.app,.*\.menyu\.com
