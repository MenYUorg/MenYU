# ── Base de datos (Supabase) ─────────────────────────────────────────────────
#
# Opción A — Conexión directa (puerto 5432)
# Suficiente para desarrollo y para "prisma migrate deploy".
DATABASE_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

# Opción B — Pooler de Supabase (PgBouncer, puerto 6543)
# Recomendado en producción cuando hay muchas conexiones concurrentes.
# Requiere agregar directUrl al datasource en schema.prisma para que las
# migraciones usen conexión directa (Railway ya la soporta como variable separada).
#
# DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET="cambia-esto-por-un-string-largo-y-aleatorio"
JWT_EXPIRES_IN="7d"

# ── App ──────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
