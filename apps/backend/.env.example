# ─────────────────────────────────────────────
# BASE DE DATOS
# ─────────────────────────────────────────────

# Conexión pooled de Prisma (usa PgBouncer de Supabase en producción)
DATABASE_URL="postgresql://postgres:password@db.xxxx.supabase.co:6543/postgres?pgbouncer=true&connection_limit=1"

# Conexión directa (usada por prisma migrate — bypasa PgBouncer)
DIRECT_URL="postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres"

# ─────────────────────────────────────────────
# SERVIDOR
# ─────────────────────────────────────────────

# Puerto en el que arranca NestJS (default: 3000)
PORT=3000

# Entorno de ejecución — en production activa SSL para PostgreSQL
NODE_ENV=development

# ─────────────────────────────────────────────
# AUTH / JWT
# ─────────────────────────────────────────────

# Clave secreta para firmar y verificar JWTs — debe ser larga y aleatoria
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# ─────────────────────────────────────────────
# SUPABASE (storage de imágenes)
# ─────────────────────────────────────────────

# URL del proyecto Supabase (se encuentra en Settings > API)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Service role key — permite acceso total al storage sin RLS (Settings > API)
# NUNCA exponer en el frontend
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key-here

# ─────────────────────────────────────────────
# MERCADO PAGO
# ─────────────────────────────────────────────
# Cada restaurante conecta su propia cuenta de MP via OAuth (ver
# mercado-pago-oauth.service.ts) — el access token queda encriptado en
# Restaurante.mpAccessToken. No hay un MP_ACCESS_TOKEN global de app.

# Clave para encriptar (AES-256-GCM) los tokens OAuth de MP por restaurante
# (ver common/crypto.service.ts). Generar con:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MP_ENCRYPTION_KEY=cambia-esto-por-un-secret-largo-y-aleatorio

# Credenciales de la app de Mercado Pago (mercadopago.com/developers/panel/app)
MP_CLIENT_ID=0000000000000000
MP_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Panel admin: http://localhost:5174 en desarrollo, https://admin.menyu.com en producción
FRONTEND_ADMIN_URL=http://localhost:5174

# URL pública del backend, con el prefijo /api (ver app.setGlobalPrefix en main.ts).
# Se usa tanto para el redirect_uri del OAuth de MP como para el notification_url
# del webhook (ver mercado-pago-oauth.service.ts y mercado-pago.provider.ts).
# En desarrollo, la URL pública de ngrok. En Railway, la URL fija del servicio.
# Debe estar registrada como redirect_uri en el dashboard de la app de MP.
BASE_URL=

# URL de apps/web-cliente (el comensal). Puerto real: 5176 (ver apps/web-cliente/vite.config.ts)
# Fallback de las back_urls de MP cuando no llega header Origin o no matchea
# CORS_ORIGIN_PATTERNS/CORS_ORIGINS (ver PaymentsService.resolveFrontendOrigin) —
# dejar un valor funcional, no vacío, para no generar una URL de redirect con "undefined".
FRONTEND_URL=

# ─────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────

# Lista de origins permitidos separados por coma (producción)
# En desarrollo todos los localhost son permitidos automáticamente
CORS_ORIGINS=https://admin.menyu.com,https://staff.menyu.com,https://menu.menyu.com

# Patrones regex de origins adicionales (útil para URLs de preview de Vercel).
# Esta misma whitelist también valida el header Origin usado para derivar las
# back_urls dinámicas de Mercado Pago (ver is-allowed-origin.ts) — un patrón
# demasiado laxo (ej. un "." sin escapar) amplía a qué dominios puede redirigir
# el checkout de MP, no solo qué puede pegarle a la API.
#
# Vercel genera dos formatos de preview bajo el team "men-yu-s-projects":
#   - por rama:       menyu-cliente-git-<rama>-men-yu-s-projects.vercel.app
#   - por deployment:  menyu-cliente-<hash>-men-yu-s-projects.vercel.app
# (mismo patrón para menyu-admin y menyu-staff)
CORS_ORIGIN_PATTERNS=^https://menyu-(cliente|admin|staff)\.vercel\.app$,^https://menyu-(cliente|admin|staff)-[a-z0-9-]+-men-yu-s-projects\.vercel\.app$
