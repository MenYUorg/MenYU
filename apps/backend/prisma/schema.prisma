generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// MARCA Y SUCURSALES
// ─────────────────────────────────────────────

model Marca {
  id         String       @id @default(uuid())
  nombre     String
  slug       String       @unique
  activo     Boolean      @default(true)
  createdAt  DateTime     @default(now()) @map("created_at")

  restaurantes Restaurante[]
  admins       Admin[]

  @@map("marca")
}

model Restaurante {
  id          String   @id @default(uuid())
  marcaId     String   @map("marca_id")
  nombre      String
  direccion   String?
  qrBaseUrl   String?  @map("qr_base_url")
  modoSesion  String   @default("abierto") @map("modo_sesion")
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")

  marca         Marca              @relation(fields: [marcaId], references: [id])
  mozos         Mozo[]
  comandas      Comanda[]
  categorias    CategoriaMenu[]
  menus         Menu[]
  mesas         Mesa[]
  ingredientes  Ingrediente[]
  items         ItemMenu[]
  admins        AdminRestaurante[]

  @@map("restaurante")
}

enum RolAdmin {
  ROOT
  OWNER
  GERENTE

  @@map("rol_admin")
}

// ─────────────────────────────────────────────
// USUARIOS DEL SISTEMA
// ─────────────────────────────────────────────

model Admin {
  id           String    @id @default(uuid())
  marcaId      String?   @map("marca_id")
  email        String    @unique
  passwordHash String    @map("password_hash")
  rol          RolAdmin

  marca        Marca?             @relation(fields: [marcaId], references: [id])
  restaurantes AdminRestaurante[]

  @@map("admin")
}

model AdminRestaurante {
  id            String @id @default(uuid())
  adminId       String @map("admin_id")
  restauranteId String @map("restaurante_id")

  admin       Admin       @relation(fields: [adminId], references: [id])
  restaurante Restaurante @relation(fields: [restauranteId], references: [id])

  @@unique([adminId, restauranteId])
  @@map("admin_restaurante")
}

model Mozo {
  id            String   @id @default(uuid())
  restauranteId String   @map("restaurante_id")
  nombre        String
  email         String?
  passwordHash  String   @map("password_hash")
  telefono      String?
  activo        Boolean  @default(true)
  esJefeSalon   Boolean  @default(false) @map("es_jefe_salon")
  createdAt     DateTime @default(now()) @map("created_at")

  restaurante   Restaurante      @relation(fields: [restauranteId], references: [id])
  asignaciones  AsignacionMesa[]
  llamados      LlamadoMozo[]

  @@map("mozo")
}

// ─────────────────────────────────────────────
// MESAS Y SESIONES
// ─────────────────────────────────────────────

model Mesa {
  id            String   @id @default(uuid())
  restauranteId String   @map("restaurante_id")
  numero        String
  qrToken       String   @unique @map("qr_token")
  pin           String
  estado        String   @default("libre")
  activo        Boolean  @default(true)

  restaurante  Restaurante      @relation(fields: [restauranteId], references: [id])
  sesiones     SesionMesa[]
  pedidos      Pedido[]
  asignaciones AsignacionMesa[]

  @@unique([restauranteId, pin])
  @@map("mesa")
}

model Cliente {
  id           String   @id @default(uuid())
  nombre       String
  email        String?  @unique
  passwordHash String?  @map("password_hash")
  telefono     String?
  createdAt    DateTime @default(now()) @map("created_at")

  sesiones       SesionMesa[]
  sesionClientes SesionMesaCliente[]
  pedidoItems    PedidoItem[]

  @@map("cliente")
}

model SesionMesa {
  id            String    @id @default(uuid())
  mesaId        String    @map("mesa_id")
  clienteId     String    @map("cliente_id")
  codigoSesion  String    @map("codigo_sesion")
  iniciadaEn    DateTime  @default(now()) @map("iniciada_en")
  cerradaEn     DateTime? @map("cerrada_en")
  estado        String    @default("activa")

  mesa          Mesa               @relation(fields: [mesaId], references: [id])
  cliente       Cliente            @relation(fields: [clienteId], references: [id])
  pedidos       Pedido[]
  asignaciones  AsignacionMesa[]
  llamados      LlamadoMozo[]
  participantes SesionMesaCliente[]

  @@map("sesion_mesa")
}

model SesionMesaCliente {
  id          String   @id @default(uuid())
  sesionId    String   @map("sesion_id")
  clienteId   String   @map("cliente_id")
  orden       Int
  ingresadoEn DateTime @default(now()) @map("ingresado_en")

  sesion  SesionMesa @relation(fields: [sesionId], references: [id])
  cliente Cliente    @relation(fields: [clienteId], references: [id])

  @@unique([sesionId, clienteId])
  @@map("sesion_mesa_cliente")
}

model AsignacionMesa {
  id          String    @id @default(uuid())
  mesaId      String    @map("mesa_id")
  mozoId      String    @map("mozo_id")
  sesionId    String    @map("sesion_id")
  origen      String
  asignadoEn  DateTime  @default(now()) @map("asignado_en")
  liberadoEn  DateTime? @map("liberado_en")

  mesa   Mesa       @relation(fields: [mesaId], references: [id])
  mozo   Mozo       @relation(fields: [mozoId], references: [id])
  sesion SesionMesa @relation(fields: [sesionId], references: [id])

  @@map("asignacion_mesa")
}

// ─────────────────────────────────────────────
// LLAMADOS (tiempo real, con persistencia mínima)
// ─────────────────────────────────────────────

model LlamadoMozo {
  id        String   @id @default(uuid())
  sesionId  String   @map("sesion_id")
  mozoId    String?  @map("mozo_id")
  estado    String   @default("pendiente")
  createdAt DateTime @default(now()) @map("created_at")

  sesion SesionMesa @relation(fields: [sesionId], references: [id])
  mozo   Mozo?      @relation(fields: [mozoId], references: [id])

  @@map("llamado_mozo")
}

// ─────────────────────────────────────────────
// MENÚ
// ─────────────────────────────────────────────

model Comanda {
  id            String @id @default(uuid())
  restauranteId String @map("restaurante_id")
  nombre        String

  restaurante Restaurante @relation(fields: [restauranteId], references: [id])
  items       ItemMenu[]

  @@map("comanda")
}

model CategoriaMenu {
  id            String @id @default(uuid())
  restauranteId String @map("restaurante_id")
  nombre        String
  orden         Int    @default(0)

  restaurante   Restaurante      @relation(fields: [restauranteId], references: [id])
  subcategorias SubcategoriaMenu[]
  items         ItemMenu[]

  @@map("categoria_menu")
}

model SubcategoriaMenu {
  id          String @id @default(uuid())
  categoriaId String @map("categoria_id")
  nombre      String
  orden       Int    @default(0)

  categoria CategoriaMenu @relation(fields: [categoriaId], references: [id])
  items     ItemMenu[]

  @@map("subcategoria_menu")
}

model ItemMenu {
  id                String   @id @default(uuid())
  restauranteId     String   @map("restaurante_id")
  categoriaId       String?  @map("categoria_id")
  subcategoriaId    String?  @map("subcategoria_id")
  comandaId         String?  @map("comanda_id")
  nombre            String
  descripcion       String?
  precioBase        Decimal  @map("precio_base") @db.Decimal(10, 2)
  disponible        Boolean  @default(true)
  imagenUrl         String?  @map("imagen_url")

  restaurante    Restaurante        @relation(fields: [restauranteId], references: [id])
  categoria      CategoriaMenu?     @relation(fields: [categoriaId], references: [id])
  subcategoria   SubcategoriaMenu?  @relation(fields: [subcategoriaId], references: [id])
  comanda        Comanda?           @relation(fields: [comandaId], references: [id])
  menus          MenuItem[]
  ingredientes   ItemIngrediente[]
  clasificaciones ItemClasificacion[]
  pedidoItems    PedidoItem[]

  @@map("item_menu")
}


model Menu {
  id            String  @id @default(uuid())
  restauranteId String  @map("restaurante_id")
  nombre        String
  dias          String?
  horaInicio    String? @map("hora_inicio")
  horaFin       String? @map("hora_fin")
  temporada     String?

  restaurante Restaurante @relation(fields: [restauranteId], references: [id])
  items       MenuItem[]

  @@map("menu")
}

model MenuItem {
  menuId String @map("menu_id")
  itemId String @map("item_id")

  menu Menu     @relation(fields: [menuId], references: [id])
  item ItemMenu @relation(fields: [itemId], references: [id])

  @@id([menuId, itemId])
  @@map("menu_item")
}

model ClasificacionDieta {
  id     String @id @default(uuid())
  nombre String @unique

  items ItemClasificacion[]

  @@map("clasificacion_dieta")
}

model ItemClasificacion {
  itemId           String @map("item_id")
  clasificacionId  String @map("clasificacion_id")

  item          ItemMenu           @relation(fields: [itemId], references: [id])
  clasificacion ClasificacionDieta @relation(fields: [clasificacionId], references: [id])

  @@id([itemId, clasificacionId])
  @@map("item_clasificacion")
}

model Ingrediente {
  id            String  @id @default(uuid())
  restauranteId String  @map("restaurante_id")
  nombre        String
  esAlergeno    Boolean @default(false) @map("es_alergeno")

  restaurante Restaurante       @relation(fields: [restauranteId], references: [id])
  items       ItemIngrediente[]

  @@map("ingrediente")
}

model ItemIngrediente {
  id            String  @id @default(uuid())
  itemId        String  @map("item_id")
  ingredienteId String  @map("ingrediente_id")
  esOriginal    Boolean @map("es_original")
  cantidad      Decimal @db.Decimal(10, 3)
  esRemovible   Boolean @default(false) @map("es_removible")
  esAgregable   Boolean @default(false) @map("es_agregable")
  precioExtra   Decimal @default(0) @map("precio_extra") @db.Decimal(10, 2)
  cantidadMin   Int     @default(0) @map("cantidad_min")
  cantidadMax   Int     @default(1) @map("cantidad_max")

  item        ItemMenu          @relation(fields: [itemId], references: [id])
  ingrediente Ingrediente       @relation(fields: [ingredienteId], references: [id])
  mods        PedidoItemMod[]

  @@unique([itemId, ingredienteId])
  @@map("item_ingrediente")
}

// ─────────────────────────────────────────────
// PEDIDOS Y PAGOS
// ─────────────────────────────────────────────

model Pedido {
  id        String   @id @default(uuid())
  sesionId  String   @map("sesion_id")
  mesaId    String   @map("mesa_id")
  estado    String   @default("pendiente")
  createdAt DateTime @default(now()) @map("created_at")

  sesion SesionMesa  @relation(fields: [sesionId], references: [id])
  mesa   Mesa        @relation(fields: [mesaId], references: [id])
  items  PedidoItem[]
  pago   Pago?

  @@map("pedido")
}

model PedidoItem {
  id             String   @id @default(uuid())
  pedidoId       String   @map("pedido_id")
  itemId         String   @map("item_id")
  clienteId      String?  @map("cliente_id")
  cantidad       Int
  precioUnitario Decimal  @map("precio_unitario") @db.Decimal(10, 2)
  notas          String?

  pedido  Pedido          @relation(fields: [pedidoId], references: [id])
  item    ItemMenu        @relation(fields: [itemId], references: [id])
  cliente Cliente?        @relation(fields: [clienteId], references: [id])
  mods    PedidoItemMod[]

  @@map("pedido_item")
}

model PedidoItemMod {
  pedidoItemId      String  @map("pedido_item_id")
  itemIngredienteId String  @map("item_ingrediente_id")
  accion            String
  cantidad          Decimal @db.Decimal(10, 3)

  pedidoItem     PedidoItem     @relation(fields: [pedidoItemId], references: [id])
  itemIngrediente ItemIngrediente @relation(fields: [itemIngredienteId], references: [id])

  @@id([pedidoItemId, itemIngredienteId])
  @@map("pedido_item_mod")
}

model Pago {
  id                String   @id @default(uuid())
  pedidoId          String   @unique @map("pedido_id")
  monto             Decimal  @db.Decimal(10, 2)
  metodo            String
  estado            String   @default("pendiente")
  referenciaExterna String?  @map("referencia_externa")
  createdAt         DateTime @default(now()) @map("created_at")

  pedido Pedido @relation(fields: [pedidoId], references: [id])

  @@map("pago")
}

// ─────────────────────────────────────────────
// AUTENTICACIÓN
// ─────────────────────────────────────────────

model RefreshToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique @map("token_hash")
  userId    String    @map("user_id")
  userTipo  String    @map("user_tipo")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("refresh_token")
}
